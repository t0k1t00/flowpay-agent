# PayGentic — Environment Variables
# Copy to .env and fill in your keys

# ── AI ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Supplier Search ──────────────────────────────
EXA_API_KEY=your_exa_key_here
FIRECRAWL_API_KEY=your_firecrawl_key_here

# ── Company Enrichment ───────────────────────────
APOLLO_API_KEY=your_apollo_key_here

# ── Email ────────────────────────────────────────
RESEND_API_KEY=your_resend_key_here
EMAIL_FROM=agent@yourcompany.com

# ── Escrow (Locus) ───────────────────────────────
LOCUS_API_KEY=your_locus_key_here
LOCUS_WALLET_ID=your_wallet_id

# ── Spending Limits ──────────────────────────────
AUTO_APPROVE_THRESHOLD=2000
MONTHLY_SPEND_LIMIT=30000
WALLET_BALANCE=50000

# ── Database ─────────────────────────────────────
DATABASE_URL=sqlite:///./paygentic.db

# ── App ──────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
