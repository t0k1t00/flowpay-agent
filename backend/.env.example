# Runtime behavior
USE_LIVE_APIS=false
USE_LOCUS_WRAPPED_APIS=false
STRICT_INTEGRATIONS=false
ENABLE_API_DOCS=false

# CORS controls
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_METHODS=GET,POST,PUT,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Api-Key

# API auth (set REQUIRE_API_KEY=true for non-local deployments)
REQUIRE_API_KEY=false
FLOWPAY_API_KEY=

# Locus gateway and financial operations
LOCUS_API_BASE=https://api.paywithlocus.com/api
LOCUS_API_KEY=
LOCUS_402_APPROVAL_ENDPOINT=/payments/approve
LOCUS_WALLET_DEBIT_ENDPOINT=/wallet/debit
LOCUS_WALLET_CREDIT_ENDPOINT=/wallet/credit
LOCUS_ESCROW_CREATE_ENDPOINT=/escrow/create
LOCUS_ESCROW_TRANSITION_ENDPOINT=/escrow/transition

# External providers
EXA_API_KEY=
FIRECRAWL_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Flowpay <noreply@flowpay.ai>
APOLLO_API_KEY=
APOLLO_ENRICH_ENDPOINT=

# Optional token used for remote A2A service endpoint authentication
A2A_SHARED_TOKEN=
A2A_ALLOWED_ENDPOINT_HOSTS=

# Provider health cache TTL (seconds)
PROVIDER_HEALTH_CACHE_TTL_SECONDS=20

# Agent model planner/parser
OPENAI_API_KEY=
AGENT_MODEL=gpt-4o-mini

# Spending controls and wallet defaults
AUTO_APPROVE_THRESHOLD=2000
MONTHLY_SPEND_LIMIT=30000
DAILY_SPEND_LIMIT=10000
WALLET_BALANCE=50000
ALLOWED_VENDOR_CATEGORIES=cotton yarn,textile dye,steel rod,machine parts